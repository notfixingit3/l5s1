# Copy to .env if you want compose/env overrides (optional; compose defaults are passkey-safe)

PORT=8080
DATA_DIR=./data
DATABASE_DSN=file:./data/l5s1.db?cache=shared&mode=rwc

# --- WebAuthn: keep stable for the life of a dev machine's passkeys ---
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGINS=http://localhost:8080
WEBAUTHN_RP_DISPLAY_NAME=L5S1 Health Registry

SEED_ADMIN_EMAIL=admin@l5s1.local
SECURE_COOKIE=false
FRONTEND_DIR=../frontend
