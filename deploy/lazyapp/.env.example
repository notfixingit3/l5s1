# Public hostnames (Traefik Host() rules + Let's Encrypt)
APP_HOST=l5s1.com
APP_HOST_WWW=www.l5s1.com

# GHCR tag — published on v*-beta.* cuts (latest = newest beta)
IMAGE_TAG=latest

# WebAuthn — RP ID is the registrable domain (no scheme/path)
# Origins: every HTTPS URL users actually open (comma-separated, no spaces needed)
WEBAUTHN_RP_ID=l5s1.com
WEBAUTHN_ORIGINS=https://l5s1.com,https://www.l5s1.com
WEBAUTHN_RP_DISPLAY_NAME=L5S1 Health Registry
SECURE_COOKIE=true

SEED_ADMIN_USERNAME=admin

# CrowdSec Traefik bouncer key (from your edge stack)
CROWDSEC_BOUNCER_KEY=
