# Lab preview host (Traefik + Let's Encrypt)
PREVIEW_HOST=l5s1.lazyapp.me

# GHCR tag — default tracks rolling dev builds
IMAGE_TAG=dev

# WebAuthn must match the public HTTPS host (not localhost)
WEBAUTHN_RP_ID=l5s1.lazyapp.me
WEBAUTHN_ORIGINS=https://l5s1.lazyapp.me
WEBAUTHN_RP_DISPLAY_NAME=L5S1 Health Registry (lab)
SECURE_COOKIE=true

SEED_ADMIN_USERNAME=admin

# Required: same CrowdSec bouncer key used by other *_lazyapp stacks
CROWDSEC_BOUNCER_KEY=
