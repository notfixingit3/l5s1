# Public hostname served by Traefik (example — change for your deploy)
PREVIEW_HOST=l5s1.example.com

# GHCR tag — images are published only on v*-beta.* tags (latest = newest beta)
IMAGE_TAG=latest

# WebAuthn must match the public HTTPS host (not localhost)
WEBAUTHN_RP_ID=l5s1.example.com
WEBAUTHN_ORIGINS=https://l5s1.example.com
WEBAUTHN_RP_DISPLAY_NAME=L5S1 Health Registry
SECURE_COOKIE=true

SEED_ADMIN_USERNAME=admin

# Optional: CrowdSec Traefik bouncer key for your edge
CROWDSEC_BOUNCER_KEY=
